.discasa-data/
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm
*.tmp
*.temp
*.bak
*.orig

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.idea/
*.code-workspace
