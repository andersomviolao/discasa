# =========================
# Discasa - Git Ignore
# =========================

# Dependencies
node_modules/

package-lock.json

# Frontend / Node build output
dist/
build/
out/
.vite/
.turbo/
coverage/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example

# Tauri / Rust build artifacts
target/
**/target/
discasa_app/apps/desktop/src-tauri/target/

# Tauri generated files
discasa_app/apps/desktop/src-tauri/gen/

# Local app data / mock data / future cache
.discasa-data/
**/.discasa-data/
discasa_app/apps/server/.discasa-data/

# Local databases and temp runtime files
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.idea/
*.code-workspace

# Archive / temp files
*.tmp
*.temp
*.bak
*.orig
