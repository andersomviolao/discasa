{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Discasa",
  "version": "0.0.0",
  "identifier": "com.andersomviolao.discasa",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @discasa/desktop",
    "beforeBuildCommand": "npm run build --workspace @discasa/desktop",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Discasa",
        "width": 1320,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
